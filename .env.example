# ══════════════════════════════════════════════════════════════
# KARTA ONE — Personal AI Assistant — Environment Variables
# Copy this file to .env and fill in your values
# Run `npm run setup` for an interactive setup wizard
# ══════════════════════════════════════════════════════════════

# ── LLM Provider ───────────────────────────────────────────────
# Options: claude | openai | gemini | groq
# Claude is REQUIRED for the self-improvement system (skill writing)
LLM_PROVIDER=claude

# Anthropic Claude — REQUIRED for self-improvement (skill writing)
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI GPT-4o — optional, used if LLM_PROVIDER=openai
# Get key: https://platform.openai.com
OPENAI_API_KEY=

# Google Gemini — optional, used if LLM_PROVIDER=gemini
# Get key: https://aistudio.google.com
GEMINI_API_KEY=

# Groq (Llama) — optional, used if LLM_PROVIDER=groq
# Get key: https://console.groq.com
GROQ_API_KEY=

# ── Telegram Bot ───────────────────────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram user ID (get from @userinfobot)
# Only this user can interact with the agent
ALLOWED_TELEGRAM_USER_ID=

# ── Default Delivery Address ───────────────────────────────────
DEFAULT_ADDRESS_LINE1=
DEFAULT_ADDRESS_LINE2=
DEFAULT_CITY=
DEFAULT_PINCODE=
DEFAULT_PHONE=
DEFAULT_NAME=

# ── Food Delivery Accounts ──────────────────────────────────────
ZOMATO_PHONE=
SWIGGY_PHONE=

# ── Optional: Web Search ────────────────────────────────────────
# Required for the search skill. Get free key: https://tavily.com
TAVILY_API_KEY=

# ── Safety Limits ───────────────────────────────────────────────
# Max COD order amount without confirmation (₹)
MAX_ORDER_AMOUNT=500
REQUIRE_CONFIRMATION=true

# ── Regional Settings ───────────────────────────────────────────
TIMEZONE=Asia/Kolkata

# ── Logging ─────────────────────────────────────────────────────
# Options: error | warn | info | debug
LOG_LEVEL=info

# ── Encryption ──────────────────────────────────────────────────
# Auto-generated on first run — do not share
ENCRYPTION_KEY=
